<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/10.5/phpunit.xsd"
         backupGlobals="false"
         stderr="true"
         bootstrap="bootstrap.php"
         colors="true">
    <testsuites>
        <testsuite name="CurrencyServices">
            <directory suffix="Test.php">Model</directory>
            <directory suffix="Test.php">Console</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>../Model</directory>
            <directory>../Console</directory>
        </include>
    </source>
    <coverage>
        <report>
            <clover outputFile="../coverage/clover.xml"/>
            <html outputDirectory="../coverage" lowUpperBound="35" highLowerBound="70"/>
        </report>
    </coverage>
</phpunit>
